# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI — para transcripción de audios con Whisper
OPENAI_API_KEY=

# Google Sheets
# El ID lo encontrás en la URL del spreadsheet: /spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Gastos
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# El JSON completo del service account, en una sola línea
GOOGLE_SERVICE_ACCOUNT_KEY=

# WhatsApp
# A qué número le llegan los resúmenes automáticos (semanales, mensuales)
# Formato: 549XXXXXXXXXX@s.whatsapp.net  (549 + número sin 0 ni 15)
WHATSAPP_SUMMARY_JID=
# qr para escanear QR, pairing para código de emparejamiento
WHATSAPP_AUTH_METHOD=qr

# App
LOG_LEVEL=info
NODE_ENV=production
PORT=3000
TZ=America/Argentina/Buenos_Aires
